meta {
  name: uploadPlaceAssets
  type: http
  seq: 6
}

post {
  url: {{base_url}}{{api_version}}/place/1/assets
  body: multipartForm
  auth: inherit
}

body:multipart-form {
  assets: @file()
}

body:file {
  file: @file(/Users/simonwehle/Downloads/InformatiKOM_16x9.jpg) @contentType(image/jpeg)
}

settings {
  encodeUrl: true
  timeout: 0
}
